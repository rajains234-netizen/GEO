[Unit]
Description=GEO Score API (FastAPI + Uvicorn)
After=network.target redis.service

[Service]
User=geo
Group=geo
WorkingDirectory=/var/www/geo
ExecStart=/var/www/geo/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5
EnvironmentFile=/var/www/geo/.env

[Install]
WantedBy=multi-user.target
