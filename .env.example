# GEO Score SaaS — Environment Variables
# Copy this to .env and fill in your values

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_ID=price_optional_if_using_inline_pricing
REPORT_PRICE_CENTS=4900

# Redis (default works for local dev)
REDIS_URL=redis://localhost:6379/0

# Database
DATABASE_URL=sqlite:///./geo_saas.db

# Email — SendGrid (get from https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
FROM_EMAIL=reports@geoscore.ai

# Claude AI — Anthropic (get from https://console.anthropic.com/settings/keys)
# This powers the deep analysis (citability, E-E-A-T, platform optimization, schema audit)
# Cost: ~$0.10-0.50 per report using claude-sonnet
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# URLs
BASE_URL=http://localhost:5173
API_URL=http://localhost:8000
